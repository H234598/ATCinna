#!/usr/bin/env python3
import argparse
import json
import os
import re
import shutil
import subprocess
import sys
from pathlib import Path

from urllib.parse import urlparse


SCRIPT_DIR = Path(__file__).resolve().parent
HELPER_PATH = SCRIPT_DIR / "atcinna-catalog"


def _is_http_url(value):
    if not value:
        return False
    try:
        parsed = urlparse(value)
        return parsed.scheme in {"http", "https"} and bool(parsed.netloc)
    except Exception:
        return False


def _coerce_bool_value(value):
    if isinstance(value, bool):
        return value
    if value is None:
        return None
    normalized = str(value).strip().lower()
    if normalized in {"1", "true", "yes", "on"}:
        return True
    if normalized in {"0", "false", "no", "off"}:
        return False
    return None


def _parse_bool_arg(value, field):
    normalized = _coerce_bool_value(value)
    if normalized is None:
        raise RuntimeError(f"{field} must be true or false")
    return normalized


def _run_helper(args):
    process = subprocess.run(
        [str(HELPER_PATH), *args],
        stdout=subprocess.PIPE,
        stderr=subprocess.PIPE,
        text=True,
        check=False,
    )
    if process.returncode != 0:
        raise RuntimeError(process.stderr.strip() or process.stdout.strip() or "helper failed")
    try:
        return json.loads(process.stdout or "{}")
    except Exception as exc:
        raise RuntimeError(f"invalid helper response: {exc}") from exc


def _normalize_folder_choice(value):
    text = str(value or "").strip()
    if not text or "\x00" in text:
        return ""
    return text


def _load_folder_history():
    try:
        payload = _run_helper(["download-folder-history-list"])
    except Exception:
        return []

    if not isinstance(payload, dict) or payload.get("status") != "ok":
        return []

    choices = []
    for value in payload.get("results", []):
        normalized = _normalize_folder_choice(value)
        if normalized:
            choices.append(normalized)
    return choices


def _folder_history_choices(current_folder, history=None):
    candidates = [_normalize_folder_choice(current_folder)]
    candidates.extend(history if history is not None else _load_folder_history())

    choices = []
    seen = set()
    for value in candidates:
        normalized = _normalize_folder_choice(value)
        if not normalized or normalized in seen:
            continue
        choices.append(normalized)
        seen.add(normalized)
    return choices


def _set_field_text(widget, value):
    text = str(value or "")
    if widget is None:
        return
    if hasattr(widget, "get_child"):
        child = widget.get_child()
        if child is not None and hasattr(child, "set_text"):
            child.set_text(text)
            return
    if hasattr(widget, "set_text"):
        widget.set_text(text)


def _clear_folder_history(folder_widget, status_label):
    current_folder = _collect_field(folder_widget)
    try:
        payload = _run_helper(["download-folder-history-clear"])
        if payload.get("status") != "ok":
            status_label.set_text(f"Pfadliste löschen fehlgeschlagen: {payload.get('message') or 'unbekannter Fehler'}")
            return
        if hasattr(folder_widget, "remove_all"):
            folder_widget.remove_all()
        _set_field_text(folder_widget, current_folder)
        status_label.set_text("Pfadliste gelöscht")
    except Exception as exc:
        status_label.set_text(f"Pfadliste löschen fehlgeschlagen: {exc}")


def _refresh_folder_space_label(folder_widget, label_widget):
    if label_widget is None:
        return
    label_widget.set_text(_folder_disk_space_label_text(_collect_field(folder_widget)))


def _disk_space_target(path_value):
    text = str(path_value or "").strip()
    if not text:
        return None

    candidate = Path(text).expanduser()
    if not candidate.is_absolute():
        return None

    if not candidate.is_dir():
        return None

    return candidate


def _folder_disk_space_label_text(path_value):
    target = _disk_space_target(path_value)
    if target is None:
        return ""

    try:
        free_bytes = shutil.disk_usage(str(target)).free
    except Exception:
        return ""

    gib = free_bytes / float(1024 ** 3)
    if gib >= 1:
        value = f"{gib:.1f} GB"
    else:
        mib = free_bytes / float(1024 ** 2)
        if mib >= 1:
            value = f"{mib:.1f} MB"
        else:
            kib = free_bytes / float(1024)
            value = f"{kib:.1f} KB"

    return f"[ noch frei: {value} ]"


def _load_queue_info_file(url):
    if not _is_http_url(url):
        return None

    try:
        payload = _run_helper(["download-list"])
    except Exception:
        return None

    if not isinstance(payload, dict) or payload.get("status") != "ok":
        return None

    normalized_url = str(url).strip()
    for entry in payload.get("results", []):
        if not isinstance(entry, dict):
            continue
        entry_url = str(entry.get("url", "")).strip()
        if entry_url != normalized_url:
            continue
        return _coerce_bool_value(entry.get("info_file"))

    return None


def _xdg_open(uri):
    if not _is_http_url(uri):
        raise ValueError("unzulässiges URL-Schema")
    try:
        subprocess.Popen(
            ["xdg-open", uri],
            stdout=subprocess.DEVNULL,
            stderr=subprocess.DEVNULL,
            close_fds=True,
            start_new_session=True,
        )
    except OSError as exc:
        raise RuntimeError(f"xdg-open failed: {exc}") from exc


def _self_test():
    gtk_available = True
    gtk_error = ""
    try:
        import gi

        gi.require_version("Gtk", "3.0")
        from gi.repository import Gtk  # noqa: F401
    except Exception as exc:
        gtk_available = False
        gtk_error = str(exc)

    payload = {
        "status": "ok",
        "helper": str(HELPER_PATH),
        "gtk3": gtk_available,
        "python": sys.executable,
    }
    if gtk_error:
        payload["gtk_error"] = gtk_error

    if not HELPER_PATH.is_file() or not os.access(HELPER_PATH, os.X_OK):
        payload["status"] = "error"
        payload["message"] = "helper not executable"
        print(json.dumps(payload, ensure_ascii=False))
        return 1

    print(json.dumps(payload, ensure_ascii=False))
    return 0


def _text_from_buffer(text_view):
    buffer = text_view.get_buffer()
    if not buffer:
        return ""
    start_iter = buffer.get_start_iter()
    end_iter = buffer.get_end_iter()
    return buffer.get_text(start_iter, end_iter, True).strip()


def _collect_field(widget):
    if widget is None:
        return ""
    if hasattr(widget, "get_child"):
        child = widget.get_child()
        if child is not None and hasattr(child, "get_text"):
            return child.get_text().strip()
    if hasattr(widget, "get_text"):
        return widget.get_text().strip()
    if hasattr(widget, "get_active_text"):
        text = widget.get_active_text()
        return text.strip() if text else ""
    return ""


def _load_xdg_download_dir():
    config_home = Path(os.environ.get("XDG_CONFIG_HOME") or (Path.home() / ".config")).expanduser()
    user_dirs_file = config_home / "user-dirs.dirs"
    if not user_dirs_file.is_file():
        return ""

    home = str(Path.home())
    try:
        for raw_line in user_dirs_file.read_text(encoding="utf-8").splitlines():
            line = raw_line.strip()
            if not line.startswith("XDG_DOWNLOAD_DIR="):
                continue

            value = line.split("=", 1)[1].strip().strip('"')
            value = value.replace("$HOME", home).replace("${HOME}", home)
            if not value:
                continue

            candidate = Path(value)
            if value.startswith("~"):
                candidate = Path(value).expanduser()
            if not candidate.is_absolute():
                continue
            if candidate.is_dir():
                return str(candidate)
    except Exception:
        return ""
    return ""


def _default_download_folder():
    xdg_candidate = _load_xdg_download_dir()
    if xdg_candidate:
        return xdg_candidate

    downloads = Path.home() / "Downloads"
    if downloads.is_dir():
        return str(downloads)

    return str(Path.home())


def _sanitize_topic_folder_name(topic):
    text = (topic or "").strip()
    if not text:
        return ""

    sanitized = re.sub(r"[\\/\x00]", " ", text)
    sanitized = re.sub(r"\s+", " ", sanitized).strip()
    sanitized = sanitized.strip(" .")
    if not sanitized or sanitized in {".", ".."}:
        return ""

    return sanitized


def _proposed_download_folder(topic):
    base = Path(_default_download_folder())
    folder_name = _sanitize_topic_folder_name(topic)
    if not folder_name:
        return str(base)

    candidate = base / folder_name
    if candidate.is_dir():
        return str(candidate)

    return str(base)


def _propose_download_folder(folder_entry, topic):
    proposed_folder = _proposed_download_folder(topic)
    if proposed_folder:
        _set_field_text(folder_entry, proposed_folder)


def _select_download_folder(parent_window, folder_entry, label_widget, gtk_module):
    Gtk = gtk_module
    dialog = Gtk.FileChooserDialog(
        title="Pfad auswählen",
        transient_for=parent_window,
        flags=Gtk.DialogFlags.MODAL,
        action=Gtk.FileChooserAction.SELECT_FOLDER,
    )
    dialog.add_button("Abbrechen", Gtk.ResponseType.CANCEL)
    dialog.add_button("Auswählen", Gtk.ResponseType.OK)
    dialog.set_default_response(Gtk.ResponseType.OK)
    current_folder = _collect_field(folder_entry)
    if current_folder and Path(current_folder).is_dir():
        dialog.set_current_folder(current_folder)
    try:
        response = dialog.run()
        if response == Gtk.ResponseType.OK:
            selected_folder = dialog.get_filename()
            if selected_folder:
                _set_field_text(folder_entry, selected_folder)
                _refresh_folder_space_label(folder_entry, label_widget)
    finally:
        dialog.destroy()


def run_dialog(url, title, folder, sender, genre, topic, date, time, duration, description, website, file_name, file_name_template, info_file, start_now=False):
    try:
        import gi

        gi.require_version("Gtk", "3.0")
        from gi.repository import Gtk  # noqa: F401
    except Exception as exc:
        raise RuntimeError(f"GTK 3 not available: {exc}") from exc

    if not HELPER_PATH.is_file() or not os.access(HELPER_PATH, os.X_OK):
        raise RuntimeError("helper executable is missing")

    if not _is_http_url(url):
        raise RuntimeError("URL must be http(s)")

    window = Gtk.Window(title="ATCinna Download ändern")
    window.set_default_size(820, 560)
    window.set_border_width(8)
    window.connect("destroy", Gtk.main_quit)
    result = {"status": "ok", "updated": 0, "cancelled": True, "start_now": False}

    root = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=8)
    window.add(root)

    def _run_open_url(uri, status_label):
        try:
            _xdg_open(uri)
            status_label.set_text("URL geöffnet")
        except Exception as exc:
            status_label.set_text(f"URL öffnen fehlgeschlagen: {exc}")

    url_row = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=8)
    url_label = Gtk.Label(label="URL:", xalign=0)
    url_label.set_hexpand(False)
    url_value = Gtk.Label(label=url, xalign=0)
    url_value.set_line_wrap(True)
    url_value.set_selectable(True)
    url_value.set_width_chars(48)
    url_value.set_max_width_chars(72)
    open_button = Gtk.Button(label="URL öffnen")
    url_row.pack_start(url_label, False, False, 0)
    url_row.pack_start(url_value, True, True, 0)
    url_row.pack_start(open_button, False, False, 0)
    root.pack_start(url_row, False, False, 0)

    grid = Gtk.Grid(column_spacing=8, row_spacing=6)
    root.pack_start(grid, False, False, 0)

    title_entry = Gtk.Entry()
    title_entry.set_text(title)
    folder_combo = Gtk.ComboBoxText.new_with_entry()
    for folder_choice in _folder_history_choices(folder):
        folder_combo.append_text(folder_choice)
    _set_field_text(folder_combo, folder)
    folder_entry = folder_combo.get_child()
    folder_picker_button = Gtk.Button(label="Pfad auswählen")
    folder_propose_button = Gtk.Button(label="Pfad vorschlagen")
    folder_clear_button = Gtk.Button(label="Liste der Pfade löschen")
    info_file_checkbox = Gtk.CheckButton(label='Infodatei anlegen: "Name.txt"')
    info_file_checkbox.set_active(bool(info_file))
    folder_picker_row = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=8)
    folder_picker_row.pack_start(folder_combo, True, True, 0)
    folder_picker_row.pack_start(folder_picker_button, False, False, 0)
    folder_picker_row.pack_start(folder_propose_button, False, False, 0)
    folder_picker_row.pack_start(folder_clear_button, False, False, 0)
    folder_space_label = Gtk.Label(label="", xalign=0)
    folder_space_label.set_line_wrap(True)
    folder_details_row = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=4)
    folder_details_row.pack_start(folder_picker_row, False, False, 0)
    folder_details_row.pack_start(folder_space_label, False, False, 0)
    sender_entry = Gtk.Entry()
    sender_entry.set_text(sender)
    genre_entry = Gtk.Entry()
    genre_entry.set_text(genre)
    topic_entry = Gtk.Entry()
    topic_entry.set_text(topic)
    date_entry = Gtk.Entry()
    date_entry.set_text(date)
    time_entry = Gtk.Entry()
    time_entry.set_text(time)
    duration_entry = Gtk.Entry()
    duration_entry.set_text(duration)
    website_entry = Gtk.Entry()
    website_entry.set_text(website)
    file_name_entry = Gtk.Entry()
    file_name_entry.set_text(file_name)
    file_name_template_entry = Gtk.Entry()
    file_name_template_entry.set_text(file_name_template)

    description_view = Gtk.TextView()
    description_view.set_monospace(False)
    description_view.set_vexpand(True)
    description_scroller = Gtk.ScrolledWindow()
    description_scroller.set_min_content_height(120)
    description_scroller.add(description_view)
    description_buffer = description_view.get_buffer()
    if description:
        description_buffer.set_text(description, -1)

    start_not_now_radio = Gtk.RadioButton(label="noch nicht starten")
    start_now_radio = Gtk.RadioButton(label="sofort starten", group=start_not_now_radio)
    if start_now:
        start_now_radio.set_active(True)
    else:
        start_not_now_radio.set_active(True)
    start_mode_row = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=8)
    start_mode_label = Gtk.Label(label="Startzeitpunkt:", xalign=0)
    start_mode_row.pack_start(start_not_now_radio, False, False, 0)
    start_mode_row.pack_start(start_now_radio, False, False, 0)

    status = Gtk.Label(label="Bereit", xalign=0)
    status.set_line_wrap(True)
    root.pack_start(status, False, False, 0)

    open_button.connect(
        "clicked",
        lambda _button: _run_open_url(url, status),
    )

    for label_text, widget, row in [
        ("Titel", title_entry, 0),
        ("Zielordner", folder_details_row, 1),
        ("Sender", sender_entry, 2),
        ("Genre", genre_entry, 3),
        ("Thema", topic_entry, 4),
        ("Datum", date_entry, 5),
        ("Uhrzeit", time_entry, 6),
        ("Dauer", duration_entry, 7),
        ("Website", website_entry, 8),
        ("Dateiname", file_name_entry, 9),
        ("Dateinamensvorlage", file_name_template_entry, 10),
    ]:
        label = Gtk.Label(label=f"{label_text}:", xalign=0)
        label.set_hexpand(False)
        grid.attach(label, 0, row, 1, 1)
        grid.attach(widget, 1, row, 1, 1)

    description_label = Gtk.Label(label="Beschreibung:", xalign=0)
    grid.attach(description_label, 0, 11, 1, 1)
    grid.attach(description_scroller, 1, 11, 1, 1)
    grid.attach(info_file_checkbox, 1, 12, 1, 1)
    grid.attach(start_mode_label, 0, 13, 1, 1)
    grid.attach(start_mode_row, 1, 13, 1, 1)

    actions = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=8)
    root.pack_start(actions, False, False, 0)

    save_button = Gtk.Button(label="Speichern")
    cancel_button = Gtk.Button(label="Abbrechen")
    actions.pack_end(save_button, False, False, 0)
    actions.pack_end(cancel_button, False, False, 0)

    controls = {
        "title": title_entry,
        "folder": folder_combo,
        "sender": sender_entry,
        "genre": genre_entry,
        "topic": topic_entry,
        "date": date_entry,
        "time": time_entry,
        "duration": duration_entry,
        "website": website_entry,
        "file_name": file_name_entry,
        "file_name_template": file_name_template_entry,
        "description": description_view,
        "info_file": info_file_checkbox,
    }

    def do_save(_button):
        arguments = [
            "download-update",
            f"--url={url}",
            f"--title={_collect_field(controls['title'])}",
            f"--sender={_collect_field(controls['sender'])}",
            f"--genre={_collect_field(controls['genre'])}",
            f"--topic={_collect_field(controls['topic'])}",
            f"--date={_collect_field(controls['date'])}",
            f"--time={_collect_field(controls['time'])}",
            f"--duration={_collect_field(controls['duration'])}",
            f"--description={_text_from_buffer(controls['description'])}",
            f"--website={_collect_field(controls['website'])}",
            f"--download-file-name={_collect_field(controls['file_name'])}",
            f"--download-file-name-template={_collect_field(controls['file_name_template'])}",
            f"--info-file={'true' if controls['info_file'].get_active() else 'false'}",
        ]
        folder_value = _collect_field(controls["folder"])
        if folder_value is not None:
            arguments.append(f"--folder={folder_value}")
        try:
            payload = _run_helper(arguments)
            if payload.get("status") != "ok":
                status.set_text(f"Speichern fehlgeschlagen: {payload.get('message') or 'unbekannter Fehler'}")
                return
            if payload.get("updated") == 0:
                status.set_text("Keine Änderung (kein Feld gesetzt)")
                return
            result.clear()
            result.update(payload)
            result["start_now"] = start_now_radio.get_active()
            status.set_text("Gespeichert")
            window.close()
        except Exception as exc:
            status.set_text(str(exc))

    save_button.connect("clicked", do_save)
    cancel_button.connect("clicked", lambda _button: window.close())
    folder_picker_button.connect("clicked", lambda _button: _select_download_folder(window, folder_combo, folder_space_label, Gtk))
    folder_propose_button.connect(
        "clicked",
        lambda _button: (
            _propose_download_folder(folder_combo, controls["topic"].get_text()),
            _refresh_folder_space_label(folder_combo, folder_space_label),
        ),
    )
    folder_clear_button.connect(
        "clicked",
        lambda _button: (
            _clear_folder_history(folder_combo, status),
            _refresh_folder_space_label(folder_combo, folder_space_label),
        ),
    )
    if folder_entry is not None and hasattr(folder_entry, "connect"):
        folder_entry.connect("changed", lambda *_args: _refresh_folder_space_label(folder_combo, folder_space_label))
    _refresh_folder_space_label(folder_combo, folder_space_label)

    window.show_all()
    Gtk.main()
    print(json.dumps(result, ensure_ascii=False))


def main():
    parser = argparse.ArgumentParser(description="ATCinna queue edit dialog")
    parser.add_argument("--self-test", action="store_true", help="Validate runtime dependencies headless")
    parser.add_argument("--url", default="", help="Target URL")
    parser.add_argument("--title", default="", help="Title")
    parser.add_argument("--folder", default="", help="Download folder")
    parser.add_argument("--sender", default="", help="Sender")
    parser.add_argument("--genre", default="", help="Genre")
    parser.add_argument("--topic", default="", help="Topic")
    parser.add_argument("--date", default="", help="Date")
    parser.add_argument("--time", default="", help="Time")
    parser.add_argument("--duration", default="", help="Duration")
    parser.add_argument("--description", default="", help="Description")
    parser.add_argument("--website", default="", help="Website")
    parser.add_argument("--download-file-name", default="", help="Download file name")
    parser.add_argument("--download-file-name-template", default="", help="Download file name template")
    parser.add_argument("--info-file", default=None, help="Whether to write metadata info file")
    parser.add_argument("--start-now", default="false", help="Start updated queue item immediately")
    args = parser.parse_args()

    if args.self_test:
        return _self_test()

    if args.info_file is None:
        info_file = _load_queue_info_file(args.url) or False
    else:
        info_file = _parse_bool_arg(args.info_file, "info-file")

    run_dialog(
        args.url,
        args.title,
        args.folder,
        args.sender,
        args.genre,
        args.topic,
        args.date,
        args.time,
        args.duration,
        args.description,
        args.website,
        args.download_file_name,
        args.download_file_name_template,
        info_file,
        _parse_bool_arg(args.start_now, "start-now"),
    )
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
