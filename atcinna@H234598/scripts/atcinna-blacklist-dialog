#!/usr/bin/env python3
import argparse
import json
import os
import subprocess
import sys
from pathlib import Path


SCRIPT_DIR = Path(__file__).resolve().parent
HELPER_PATH = SCRIPT_DIR / "atcinna-catalog"


def _run_helper(args):
    process = subprocess.run(
        [str(HELPER_PATH), *args],
        stdout=subprocess.PIPE,
        stderr=subprocess.PIPE,
        text=True,
        check=False,
    )
    if process.returncode != 0:
        raise RuntimeError(process.stderr.strip() or process.stdout.strip() or "helper failed")
    try:
        payload = json.loads(process.stdout or "{}")
    except Exception as exc:
        raise RuntimeError(f"invalid helper response: {exc}") from exc
    if payload.get("status") != "ok":
        raise RuntimeError(payload.get("message") or "helper returned error")
    return payload


def _self_test():
    gtk_available = True
    gtk_error = ""
    try:
        import gi

        gi.require_version("Gtk", "3.0")
        from gi.repository import Gtk  # noqa: F401
    except Exception as exc:
        gtk_available = False
        gtk_error = str(exc)

    payload = {
        "status": "ok",
        "helper": str(HELPER_PATH),
        "gtk3": gtk_available,
        "python": sys.executable,
    }
    if gtk_error:
        payload["gtk_error"] = gtk_error

    if not HELPER_PATH.is_file() or not os.access(HELPER_PATH, os.X_OK):
        payload["status"] = "error"
        payload["message"] = "helper not executable"
        print(json.dumps(payload, ensure_ascii=False))
        return 1

    print(json.dumps(payload, ensure_ascii=False))
    return 0


def _rule_to_text(rule):
    sender = str(rule.get("sender") or "").strip()
    genre = str(rule.get("genre") or "").strip()
    topic = str(rule.get("topic") or "").strip()
    title = str(rule.get("title") or "").strip()
    theme_title = str(rule.get("theme_title") or "").strip()
    active = bool(rule.get("active", True))
    topic_exact = bool(rule.get("topic_exact", True))

    parts = []
    if sender:
        parts.append(f"Sender: {sender}")
    if genre:
        parts.append(f"Genre: {genre}")
    if topic:
        parts.append(f"Thema: {topic}")
    if title:
        parts.append(f"Titel: {title}")
    if theme_title:
        parts.append(f"Thema/Titel: {theme_title}")

    state = "aktiv" if active else "inaktiv"
    mode = "exakt" if topic_exact else "enthält"
    return " · ".join(parts) + f" [{state}, Thema {mode}]" if parts else f"(leere Regel) [{state}, Thema {mode}]"


def _rule_from_row(row):
    return {
        "sender": str(row["sender"] or ""),
        "genre": str(row["genre"] or ""),
        "topic": str(row["topic"] or ""),
        "title": str(row["title"] or ""),
        "theme_title": str(row["theme_title"] or ""),
        "active": bool(row.get("active", True)),
        "topic_exact": bool(row.get("topic_exact", True)),
    }


def _build_row(rule, gtk_module):
    Gtk = gtk_module
    sender = str(rule.get("sender") or "").strip()
    genre = str(rule.get("genre") or "").strip()
    topic = str(rule.get("topic") or "").strip()
    title = str(rule.get("title") or "").strip()
    theme_title = str(rule.get("theme_title") or "").strip()

    row = Gtk.ListBoxRow()
    container = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=8)
    row.add(container)

    check = Gtk.CheckButton()
    container.pack_start(check, False, False, 0)

    label = Gtk.Label(label=_rule_to_text(rule), xalign=0)
    label.set_hexpand(True)
    label.set_xalign(0)
    container.pack_start(label, True, True, 0)

    row.set_data("sender", sender)
    row.set_data("genre", genre)
    row.set_data("topic", topic)
    row.set_data("title", title)
    row.set_data("theme_title", theme_title)
    row.set_data("active", bool(rule.get("active", True)))
    row.set_data("topic_exact", bool(rule.get("topic_exact", True)))
    row.set_data("check", check)
    return row


def _set_status(label, message):
    if label:
        label.set_text(message)


def _show_clear_confirm(parent, Gtk):
    dialog = Gtk.MessageDialog(
        transient_for=parent,
        flags=Gtk.DialogFlags.MODAL,
        type=Gtk.MessageType.WARNING,
        buttons=Gtk.ButtonsType.NONE,
        text="Alle Blacklist-Regeln entfernen?",
    )
    dialog.format_secondary_text("Diese Aktion kann mit Undo wiederhergestellt werden.")
    dialog.add_buttons("Abbrechen", Gtk.ResponseType.CANCEL, "Alles entfernen", Gtk.ResponseType.OK)
    response = dialog.run()
    dialog.destroy()
    return response == Gtk.ResponseType.OK


def run_dialog():
    if not HELPER_PATH.is_file() or not os.access(HELPER_PATH, os.X_OK):
        raise RuntimeError("helper executable is missing")

    try:
        import gi

        gi.require_version("Gtk", "3.0")
        from gi.repository import Gtk  # noqa: F401
    except Exception as exc:
        raise RuntimeError(f"GTK 3 not available: {exc}") from exc

    from gi.repository import Gtk

    window = Gtk.Window(title="ATCinna Blacklist verwalten")
    window.set_default_size(920, 560)
    window.set_border_width(8)
    window.connect("destroy", Gtk.main_quit)

    root = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=8)
    window.add(root)

    form = Gtk.Grid(column_spacing=8, row_spacing=6)
    sender_entry = Gtk.Entry()
    genre_entry = Gtk.Entry()
    topic_entry = Gtk.Entry()
    title_entry = Gtk.Entry()
    theme_title_entry = Gtk.Entry()
    sender_entry.set_placeholder_text("Sender")
    genre_entry.set_placeholder_text("Genre")
    topic_entry.set_placeholder_text("Thema")
    title_entry.set_placeholder_text("Titel")
    theme_title_entry.set_placeholder_text("Thema oder Titel")

    active_check = Gtk.CheckButton(label="aktiv")
    active_check.set_active(True)
    topic_exact_check = Gtk.CheckButton(label="Thema exakt")
    topic_exact_check.set_active(True)

    form.attach(Gtk.Label(label="Neue Regel"), 0, 0, 2, 1)
    form.attach(sender_entry, 0, 1, 1, 1)
    form.attach(genre_entry, 1, 1, 1, 1)
    form.attach(topic_entry, 2, 1, 1, 1)
    form.attach(title_entry, 3, 1, 1, 1)
    form.attach(theme_title_entry, 4, 1, 1, 1)
    form.attach(active_check, 5, 1, 1, 1)
    form.attach(topic_exact_check, 6, 1, 1, 1)
    add_rule_button = Gtk.Button(label="Neue Regel hinzufügen")
    count_hits_button = Gtk.Button(label="Treffer zählen")
    form.attach(add_rule_button, 7, 1, 1, 1)
    form.attach(count_hits_button, 8, 1, 1, 1)
    root.pack_start(form, False, False, 0)

    list_box = Gtk.ListBox(selection_mode=Gtk.SelectionMode.NONE)
    list_scroller = Gtk.ScrolledWindow()
    list_scroller.set_vexpand(True)
    list_scroller.add(list_box)
    root.pack_start(list_scroller, True, True, 0)

    status_label = Gtk.Label(label="", xalign=0)
    status_label.get_style_context().add_class("dim-label")
    root.pack_start(status_label, False, False, 0)

    selection_actions = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=8)
    select_all_button = Gtk.Button(label="Alles auswählen")
    invert_selection_button = Gtk.Button(label="Auswahl umkehren")
    reset_table_button = Gtk.Button(label="Tabelle zurücksetzen")
    selection_actions.pack_start(select_all_button, False, False, 0)
    selection_actions.pack_start(invert_selection_button, False, False, 0)
    selection_actions.pack_start(reset_table_button, False, False, 0)
    root.pack_start(selection_actions, False, False, 0)

    hint_label = Gtk.Label(label="Hinweis: `!:` vor dem Suchwert bedeutet Ausschluss (z. B. `!:wdr`). Prefix `#:` wird bewusst nicht unterstützt.")
    hint_label.set_xalign(0)
    hint_label.set_line_wrap(True)
    hint_label.set_line_wrap_mode(Gtk.WrapMode.WORD)
    hint_label.get_style_context().add_class("dim-label")
    root.pack_start(hint_label, False, False, 0)

    actions = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=8)
    remove_button = Gtk.Button(label="Markierte Regeln entfernen")
    undo_button = Gtk.Button(label="Gelöschte wieder anlegen")
    clean_button = Gtk.Button(label="Putzen")
    clear_button = Gtk.Button(label="Alle entfernen")
    close_button = Gtk.Button(label="Schließen")
    actions.pack_start(remove_button, False, False, 0)
    actions.pack_start(undo_button, False, False, 0)
    actions.pack_start(clean_button, False, False, 0)
    actions.pack_start(clear_button, False, False, 0)
    actions.pack_end(close_button, False, False, 0)
    root.pack_start(actions, False, False, 0)

    rows = []

    def refresh_rules():
        for row in list(rows):
            list_box.remove(row)
        rows.clear()

        payload = _run_helper(["blacklist-list"])
        rules = payload.get("results", [])
        if not isinstance(rules, list):
            raise RuntimeError("helper returned invalid blacklist format")

        for rule in rules:
            if not isinstance(rule, dict):
                continue
            row = _build_row(rule, Gtk)
            row.set_tooltip_text(_rule_to_text(rule))
            list_box.add(row)
            rows.append(row)

        if not rows:
            empty = Gtk.ListBoxRow()
            label = Gtk.Label(label="Keine Blacklist-Regeln", xalign=0)
            empty.add(label)
            list_box.add(empty)

        list_box.show_all()

    def _set_all_rule_checks(active):
        changed = 0
        for row in rows:
            check = row.get_data("check")
            if not check:
                continue
            if check.get_active() != active:
                changed += 1
            check.set_active(active)
        return changed

    def select_all_rules(_btn):
        changed = _set_all_rule_checks(True)
        _set_status(status_label, f"Alles auswählen: {len(rows)} Regel(n), {changed} geändert")

    def invert_rule_selection(_btn):
        changed = 0
        selected = 0
        for row in rows:
            check = row.get_data("check")
            if not check:
                continue
            next_state = not check.get_active()
            check.set_active(next_state)
            changed += 1
            if next_state:
                selected += 1
        _set_status(status_label, f"Auswahl umkehren: {selected} Regel(n) ausgewählt, {changed} geändert")

    def reset_table_selection(_btn):
        changed = _set_all_rule_checks(False)
        _set_status(status_label, f"Tabelle zurückgesetzt: {changed} Auswahl(en) entfernt")

    def load_rule_into_form(row):
        if not row or not row.get_data("check"):
            return
        sender_entry.set_text(str(row.get_data("sender") or ""))
        genre_entry.set_text(str(row.get_data("genre") or ""))
        topic_entry.set_text(str(row.get_data("topic") or ""))
        title_entry.set_text(str(row.get_data("title") or ""))
        theme_title_entry.set_text(str(row.get_data("theme_title") or ""))
        active_check.set_active(bool(row.get_data("active")))
        topic_exact_check.set_active(bool(row.get_data("topic_exact")))
        _set_status(status_label, "Regel ins Formular übernommen")

    def _collect_selected_rules():
        selected = []
        for row in rows:
            check = row.get_data("check")
            if not check or not check.get_active():
                continue
            selected_rule = _rule_from_row({
                "sender": row.get_data("sender"),
                "genre": row.get_data("genre"),
                "topic": row.get_data("topic"),
                "title": row.get_data("title"),
                "theme_title": row.get_data("theme_title"),
                "active": row.get_data("active"),
                "topic_exact": row.get_data("topic_exact"),
            })
            if selected_rule["sender"] or selected_rule["genre"] or selected_rule["topic"] or selected_rule["title"] or selected_rule["theme_title"]:
                selected.append(selected_rule)
        return selected

    def _form_rule_args(action):
        fields = {
            "sender": sender_entry.get_text().strip(),
            "genre": genre_entry.get_text().strip(),
            "topic": topic_entry.get_text().strip(),
            "title": title_entry.get_text().strip(),
            "theme_title": theme_title_entry.get_text().strip(),
        }
        if not any(fields.values()):
            return None
        args = [
            action,
            f"--active={'true' if active_check.get_active() else 'false'}",
            f"--topic-exact={'true' if topic_exact_check.get_active() else 'false'}",
        ]
        if fields["sender"]:
            args.append(f"--sender={fields['sender']}")
        if fields["genre"]:
            args.append(f"--genre={fields['genre']}")
        if fields["topic"]:
            args.append(f"--topic={fields['topic']}")
        if fields["title"]:
            args.append(f"--title={fields['title']}")
        if fields["theme_title"]:
            args.append(f"--theme-title={fields['theme_title']}")
        return args

    def add_rule(_btn):
        args = _form_rule_args("blacklist-add")
        if args is None:
            _set_status(status_label, "Bitte mindestens ein Feld befüllen")
            return

        try:
            _run_helper(args)
            sender_entry.set_text("")
            genre_entry.set_text("")
            topic_entry.set_text("")
            title_entry.set_text("")
            theme_title_entry.set_text("")
            refresh_rules()
            _set_status(status_label, "Neue Regel gespeichert")
        except Exception as exc:
            _set_status(status_label, str(exc))

    def count_rule_hits(_btn):
        args = _form_rule_args("blacklist-count")
        if args is None:
            _set_status(status_label, "Bitte mindestens ein Feld befüllen")
            return

        try:
            payload = _run_helper(args)
            hits = int(payload.get("count", 0) or 0)
            _set_status(status_label, f"Treffer zählen: {hits} Treffer")
        except Exception as exc:
            _set_status(status_label, str(exc))

    def remove_selected(_btn):
        selected = _collect_selected_rules()
        if not selected:
            _set_status(status_label, "Bitte mindestens eine Regel auswählen")
            return

        try:
            removed = 0
            for rule in selected:
                args = [
                    "blacklist-remove",
                    f"--active={'true' if rule['active'] else 'false'}",
                    f"--topic-exact={'true' if rule['topic_exact'] else 'false'}",
                ]
                if rule["sender"]:
                    args.append(f"--sender={rule['sender']}")
                if rule["genre"]:
                    args.append(f"--genre={rule['genre']}")
                if rule["topic"]:
                    args.append(f"--topic={rule['topic']}")
                if rule["title"]:
                    args.append(f"--title={rule['title']}")
                if rule["theme_title"]:
                    args.append(f"--theme-title={rule['theme_title']}")
                remove_payload = _run_helper(args)
                removed += int(remove_payload.get("removed", 0) or 0)

            refresh_rules()
            _set_status(status_label, f"{removed} Regel(n) entfernt")
        except Exception as exc:
            _set_status(status_label, str(exc))

    def undo_last(_btn):
        try:
            payload = _run_helper(["blacklist-undo"])
            restored = int(payload.get("restored", 0) or 0)
            refresh_rules()
            _set_status(status_label, f"{restored} Regel(n) wiederhergestellt")
        except Exception as exc:
            _set_status(status_label, str(exc))

    def clean_list(_btn):
        try:
            payload = _run_helper(["blacklist-clean"])
            removed = int(payload.get("removed", 0) or 0)
            refresh_rules()
            _set_status(status_label, f"{removed} leere/doppelte Regel(n) entfernt")
        except Exception as exc:
            _set_status(status_label, str(exc))

    def clear_list(_btn):
        if not _show_clear_confirm(window, Gtk):
            return
        try:
            payload = _run_helper(["blacklist-clear"])
            removed = int(payload.get("removed", 0) or 0)
            refresh_rules()
            _set_status(status_label, f"{removed} Regel(n) entfernt")
        except Exception as exc:
            _set_status(status_label, str(exc))

    def close_dialog(_btn):
        window.close()

    add_rule_button.connect("clicked", add_rule)
    count_hits_button.connect("clicked", count_rule_hits)
    select_all_button.connect("clicked", select_all_rules)
    invert_selection_button.connect("clicked", invert_rule_selection)
    reset_table_button.connect("clicked", reset_table_selection)
    list_box.connect("row-activated", lambda _list_box, row: load_rule_into_form(row))
    remove_button.connect("clicked", remove_selected)
    undo_button.connect("clicked", undo_last)
    clean_button.connect("clicked", clean_list)
    clear_button.connect("clicked", clear_list)
    close_button.connect("clicked", close_dialog)

    refresh_rules()
    window.show_all()
    Gtk.main()


def main():
    parser = argparse.ArgumentParser(description="ATCinna blacklist management dialog")
    parser.add_argument("--self-test", action="store_true", help="Validate runtime dependencies headless")
    args = parser.parse_args()

    if args.self_test:
        return _self_test()

    run_dialog()
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
