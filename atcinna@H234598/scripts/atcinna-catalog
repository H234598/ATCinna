def _queue_path():
    return data_dir() / "download-queue.json"


def _undo_path():
    return data_dir() / "download-queue-undo.json"


def _normalize_queue_entry(entry):
    if not isinstance(entry, dict):
        return None

    status = _normalize_entry_value(entry.get("status"))
    if status not in QUEUE_STATUSES:
        return None

    try:
        timestamp = int(entry.get("timestamp", int(time.time())))
    except (TypeError, ValueError):
        timestamp = int(time.time())

    return {
        "title": _normalize_entry_value(entry.get("title")),
        "sender": _normalize_entry_value(entry.get("sender")),
        "genre": _normalize_entry_value(entry.get("genre")),
        "topic": _normalize_entry_value(entry.get("topic")),
        "date": _normalize_entry_value(entry.get("date")),
        "time": _normalize_entry_value(entry.get("time")),
        "duration": _normalize_entry_value(entry.get("duration")),
        "description": _normalize_entry_value(entry.get("description")),
        "url": _normalize_entry_value(entry.get("url")),
        "website": _normalize_entry_value(entry.get("website")),
        "folder": _normalize_entry_value(entry.get("folder")),
        "timestamp": timestamp,
        "status": status,
        "path": _normalize_entry_value(entry.get("path")),
        "error": _normalize_entry_value(entry.get("error")),
    }


def _load_queue():
    normalized = []
    for entry in _load_list(_queue_path()):
        normalized_entry = _normalize_queue_entry(entry)
        if normalized_entry:
            normalized.append(normalized_entry)
    return normalized


def _store_queue(entries):
    _store_list(_queue_path(), entries)


def _load_undo():
    normalized = []
    for entry in _load_list(_undo_path()):
        normalized_entry = _normalize_queue_entry(entry)
        if normalized_entry:
            normalized.append(normalized_entry)
    return normalized


def _store_undo(entries):
    _store_list(_undo_path(), entries)


def _entry_from_args_with_folder(args):
    item = _entry_from_args(args)
    item["folder"] = _normalize_entry_value(args.folder)
    item["status"] = "queued"
    item["path"] = ""
    item["error"] = ""
    return item


def _resolve_updated_folder(raw_folder):
    folder = _normalize_entry_value(raw_folder)
    if folder == "":
        return ""

    folder_path = Path(folder).expanduser().resolve()
    if not folder_path.is_dir():
        die("queue folder does not exist")
    if not os.access(folder_path, os.W_OK | os.X_OK):
        die("queue folder is not writable")
    return str(folder_path)


def _download_file_path(url, folder, title):
    parsed = urlparse(url)
    stem = _safe_filename(_normalize_entry_value(title) or Path(parsed.path).name or "stream")
    suffix = Path(parsed.path).suffix or ".mp3"
    file_name = f"{stem}{suffix}"
    destination = folder / file_name
    candidate = 1
    while destination.exists():
        destination = folder / f"{stem}_{candidate}{suffix}"
        candidate += 1

    return str(destination)


def _download_to_file(url, folder, title):
    if not _is_http_url(url):
        die("invalid URL scheme")

    curl = shutil.which("curl")
    if not curl:
        die("curl not found")

    destination = Path(_download_file_path(url, folder, title))
    subprocess.run(
        [curl, "--fail", "--location", "--silent", "--show-error", "-L", "-o", str(destination), url],
        stdout=subprocess.PIPE,
        stderr=subprocess.PIPE,
        check=True,
        timeout=120,
    )
    return str(destination)


def _resolve_download_folder(folder):
    folder_path = Path(_normalize_entry_value(folder) or "~/Downloads").expanduser()
    if not folder_path.is_absolute():
        folder_path = folder_path.resolve()
    ensure_dir(folder_path)
    return folder_path


def _resolve_existing_queue_folder(entry):
    folder_path = Path(_normalize_entry_value(entry.get("folder")) or "~/Downloads").expanduser()
    if not folder_path.is_absolute():
        folder_path = folder_path.resolve()
    resolved_folder = folder_path.resolve(strict=True)
    if not resolved_folder.is_dir():
        die("queue folder is not a directory")
    return resolved_folder


def _path_within_folder(file_path, folder_path):
    try:
        Path(file_path).relative_to(Path(folder_path))
    except ValueError:
        return False
    return Path(file_path) != Path(folder_path)


def action_download_enqueue(args):
    _validate_and_normalize_url("url", args.url)
    _validate_and_normalize_url("website", args.website)
    item = _entry_from_args_with_folder(args)
    with _store_lock(_queue_path()):
        entries = _load_queue()
        entries = [entry for entry in entries if entry.get("url") != item["url"]]
        item["timestamp"] = int(time.time())
        entries.append(item)
        if QUEUE_MAX_ENTRIES > 0:
            entries = entries[-QUEUE_MAX_ENTRIES:]
        _store_queue(entries)
    print(json.dumps({"status": "ok"}))


def action_download_list(args):
    entries = _load_queue()
    print(json.dumps({"status": "ok", "count": len(entries), "results": entries}))


def _remove_entry_by_url(queue_entries, target_url):
    removed = []
    remaining = []
    for entry in queue_entries:
        if entry.get("url") == target_url and entry.get("status") != "running":
            removed.append(entry)
            continue
        remaining.append(entry)
    return remaining, removed


def action_download_remove(args):
    _validate_and_normalize_url("url", args.url)
    target = _normalize_entry_value(args.url)
    with _store_lock(_queue_path()):
        entries = _load_queue()
        queue_entries, removed = _remove_entry_by_url(entries, target)
        if removed:
            _store_queue(queue_entries)
            _store_undo(removed[-UNDO_MAX_ENTRIES:])
        print(json.dumps({
            "status": "ok",
            "removed": len(removed),
            "running_blocks": sum(1 for entry in entries if entry.get("url") == target and entry.get("status") == "running")
        }))


def _coerce_update_field(value):
    if value is None:
        return None
    return _normalize_entry_value(value)


def action_download_update(args):
    _validate_and_normalize_url("url", args.url)
    target = _normalize_entry_value(args.url)

    updates = {
        "title": _coerce_update_field(args.title),
        "sender": _coerce_update_field(args.sender),
        "genre": _coerce_update_field(args.genre),
        "topic": _coerce_update_field(args.topic),
        "date": _coerce_update_field(args.date),
        "time": _coerce_update_field(args.time),
        "duration": _coerce_update_field(args.duration),
        "description": _coerce_update_field(args.description),
        "website": _coerce_update_field(args.website),
        "folder": _coerce_update_field(args.folder),
    }

    if all(value is None for value in updates.values()):
        die("at least one update field is required")

    if updates["website"] is not None:
        _validate_and_normalize_url("website", updates["website"])

    if updates["folder"] is not None:
        updates["folder"] = _resolve_updated_folder(updates["folder"])

    running_blocks = 0
    updated = 0
    with _store_lock(_queue_path()):
        entries = _load_queue()
        for entry in entries:
            if entry.get("url") != target:
                continue

            if entry.get("status") == "running":
                running_blocks += 1
                continue

            changed_path = False

            if updates["title"] is not None:
                entry["title"] = updates["title"]
                changed_path = True
            if updates["sender"] is not None:
                entry["sender"] = updates["sender"]
            if updates["genre"] is not None:
                entry["genre"] = updates["genre"]
            if updates["topic"] is not None:
                entry["topic"] = updates["topic"]
            if updates["date"] is not None:
                entry["date"] = updates["date"]
            if updates["time"] is not None:
                entry["time"] = updates["time"]
            if updates["duration"] is not None:
                entry["duration"] = updates["duration"]
            if updates["description"] is not None:
                entry["description"] = updates["description"]
            if updates["website"] is not None:
                entry["website"] = updates["website"]
            if updates["folder"] is not None:
                entry["folder"] = updates["folder"]
                changed_path = True

            entry["timestamp"] = int(time.time())
            if entry.get("status") != "finished" and changed_path:
                entry["path"] = ""
            updated += 1

        if updated > 0:
            _store_queue(entries)

    print(json.dumps({
        "status": "ok",
        "updated": updated,
        "running_blocks": running_blocks
    }))


def action_download_undo(args):
    with _store_lock(_queue_path()):
        queue_entries = _load_queue()
        removed_entries = _load_undo()
        if not removed_entries:
            print(json.dumps({"status": "ok", "restored": 0}))
            return

        existing_urls = {entry.get("url") for entry in queue_entries if entry.get("url")}
        to_restore = []
        for entry in removed_entries:
            url = _normalize_entry_value(entry.get("url"))
            if not url or url in existing_urls:
                continue
            existing_urls.add(url)
            to_restore.append(entry)

        if to_restore:
            queue_entries.extend(to_restore)
            queue_entries = queue_entries[-QUEUE_MAX_ENTRIES:]
            _store_queue(queue_entries)

        _store_undo([])
        print(json.dumps({
            "status": "ok",
            "restored": len(to_restore)
        }))


def action_download_prefer(args):
    _validate_and_normalize_url("url", args.url)
    target = _normalize_entry_value(args.url)
    with _store_lock(_queue_path()):
        entries = _load_queue()
        target_index = None
        for index, entry in enumerate(entries):
            if entry.get("url") == target and entry.get("status") == "queued":
                target_index = index
                break
        if target_index is None:
            print(json.dumps({"status": "ok", "moved": False}))
            return

        entry = entries.pop(target_index)
        for insert_index, existing in enumerate(entries):
            if existing.get("status") == "queued":
                entries.insert(insert_index, entry)
                _store_queue(entries)
                print(json.dumps({"status": "ok", "moved": True, "url": target}))
                return
        entries.append(entry)
        _store_queue(entries)
        print(json.dumps({"status": "ok", "moved": True, "url": target}))


def action_download_put_back(args):
    _validate_and_normalize_url("url", args.url)
    target = _normalize_entry_value(args.url)
    with _store_lock(_queue_path()):
        entries = _load_queue()
        target_index = None
        for index, entry in enumerate(entries):
            if entry.get("url") == target and entry.get("status") == "queued":
                target_index = index
                break
        if target_index is None:
            print(json.dumps({"status": "ok", "moved": False}))
            return

        entry = entries.pop(target_index)
        insert_index = None
        for scan_index in range(len(entries) - 1, -1, -1):
            if entries[scan_index].get("status") == "queued":
                insert_index = scan_index + 1
                break
        if insert_index is None:
            insert_index = len(entries)
        entries.insert(insert_index, entry)
        _store_queue(entries)
        print(json.dumps({"status": "ok", "moved": True, "url": target}))


def action_download_run_next(args):
    with _store_lock(_queue_path()):
        entries = _load_queue()
        queue_index = None
        for index, entry in enumerate(entries):
            if entry.get("status") == "queued":
                queue_index = index
                break

        if queue_index is None:
            print(json.dumps({"status": "ok", "state": "empty"}))
            return

        entry = dict(entries[queue_index])
        entry["status"] = "running"
        entry["timestamp"] = int(time.time())
        entry["path"] = ""
        entry["error"] = ""
        entries[queue_index] = entry
        _store_queue(entries)

    download_status = "finished"
    destination = ""
    error = ""
    try:
        folder = _resolve_download_folder(entry.get("folder", ""))
        destination = _download_to_file(entry.get("url", ""), folder, entry.get("title", ""))
    except subprocess.CalledProcessError as exc:
        download_status = "error"
        error = (exc.stderr or b"").decode("utf-8", "replace").strip() or str(exc)
    except Exception as exc:
        download_status = "error"
        error = str(exc)

    with _store_lock(_queue_path()):
        entries = _load_queue()
        for existing in entries:
            if existing.get("url") != entry.get("url"):
                continue
            if existing.get("status") == "running":
                existing["status"] = download_status
                existing["path"] = destination
                existing["error"] = error
                existing["timestamp"] = int(time.time())
                break
            if existing.get("status") == "queued":
                # In case cancellation/normalisation shifted while running, only the first match.
                existing["status"] = download_status
                existing["path"] = destination
                existing["error"] = error
                existing["timestamp"] = int(time.time())
                break
        _store_queue(entries)

    print(json.dumps({
        "status": "ok",
        "result": {
            "url": entry.get("url", ""),
            "status": download_status,
            "path": destination,
            "error": error,
        }
    }))


def action_download_cancel(args):
    if not args.all and not args.queued_only:
        if not _normalize_entry_value(args.url):
            die("url is required unless --all or --queued-only is used")
    if _normalize_entry_value(args.url):
        _validate_and_normalize_url("url", args.url)

    target = _normalize_entry_value(args.url)
    changed = 0
    cancellable_statuses = ("queued",) if args.queued_only else ("queued", "running")
    with _store_lock(_queue_path()):
        entries = _load_queue()
        for entry in entries:
            if entry.get("status") not in cancellable_statuses:
                continue
            matches_all_target = args.all or (args.queued_only and not target)
            if matches_all_target or entry.get("url") == target:
                entry["status"] = "cancelled"
                entry["path"] = ""
                entry["error"] = ""
                entry["timestamp"] = int(time.time())
                changed += 1
        _store_queue(entries)
    print(json.dumps({"status": "ok", "changed": changed}))


def action_download_clear(args):
    with _store_lock(_queue_path()):
        entries = _load_queue()
        filtered = [entry for entry in entries if entry.get("status") not in ("finished", "error", "cancelled")]
        removed = len(entries) - len(filtered)
        _store_queue(filtered)
    print(json.dumps({"status": "ok", "removed": removed}))


def action_download_trash_file(args):
    _validate_and_normalize_url("url", args.url)
    target = _normalize_entry_value(args.url)
    if not target:
        die("url is required")

    with _store_lock(_queue_path()):
        entries = _load_queue()
        target_entry = None
        target_index = None
        for index, entry in enumerate(entries):
            if entry.get("url") == target:
                target_entry = entry
                target_index = index
                break
        if target_entry is None:
            die("url not found in queue")

        raw_path = _normalize_entry_value(target_entry.get("path"))
        if not raw_path:
            die("path is required")

        file_path = Path(raw_path)
        if not file_path.is_absolute():
            die("path is not absolute")

        try:
            resolved_file = file_path.resolve(strict=True)
        except FileNotFoundError:
            die("file does not exist")
        except OSError as exc:
            die(f"failed to resolve file path: {exc}")
        if not resolved_file.is_file():
            die("path is not a regular file")

        try:
            folder_path = _resolve_existing_queue_folder(target_entry)
        except FileNotFoundError:
            die("queue folder does not exist")
        except OSError as exc:
            die(f"failed to resolve queue folder: {exc}")

        if not _path_within_folder(resolved_file, folder_path):
            die("file path is outside queue folder")

        gio = shutil.which("gio")
        if not gio:
            die("gio not found")

        try:
            completed = subprocess.run(
                [gio, "trash", str(resolved_file)],
                stdout=subprocess.PIPE,
                stderr=subprocess.PIPE,
                check=False,
                timeout=30,
            )
        except Exception as exc:
            die(f"failed to execute gio trash: {exc}")

        if completed.returncode != 0:
            error = (completed.stderr or b"").decode("utf-8", "replace").strip()
            die(error or f"gio trash failed with exit {completed.returncode}")

        target_entry["path"] = ""
        target_entry["status"] = "cancelled"
        target_entry["error"] = "Datei in den Papierkorb verschoben"
        target_entry["timestamp"] = int(time.time())
        entries[target_index] = target_entry
        _store_queue(entries)
    print(json.dumps({"status": "ok", "trashed": True, "url": target}))


def _iter_audio_rows(path):
    if not path.exists():
        return

    with lzma.open(path, "rt", encoding="utf-8", errors="replace") as handle:
        for line in handle:
            text = line.strip()
            if not text or '"Audios"' not in text:
                continue
            match = re.search(r'"Audios"\s*:\s*(\[.*\])\s*,?\s*$', text)
            if not match:
                continue
            try:
                row = json.loads(match.group(1))
            except json.JSONDecodeError:
                continue
            if not isinstance(row, list) or not row:
                continue
            if row[0] == "Sender":
                continue
            yield row


def _count_audio_rows(path):
    return sum(1 for _ in _iter_audio_rows(path))


def action_refresh(args):
    target_cache = cache_dir() / "audios.xz"
    tmp_cache = cache_dir() / "audios.xz.tmp"
    ensure_dir(cache_dir())

    mirrors = []
    if args.mirror:
        mirrors.append(args.mirror)
    mirrors.extend(m for m in MIRRORS if m not in mirrors)
    curl = shutil.which("curl")
    if not curl:
        die("curl not found")

    for mirror in mirrors:
        if not _is_http_url(mirror):
            print(json.dumps({"status": "warning", "mirror": mirror, "message": "invalid mirror URL"}))
            continue
        try:
            completed = subprocess.run(
                [curl, "--fail", "--location", "--silent", "--show-error", "--max-time", "60", mirror],
                stdout=subprocess.PIPE,
                stderr=subprocess.PIPE,
                check=False,
                timeout=60,
            )
        except Exception as exc:
            print(json.dumps({"status": "warning", "mirror": mirror, "message": str(exc)}))
            continue

        if completed.returncode != 0:
            print(json.dumps({"status": "warning", "mirror": mirror, "message": completed.stderr.decode("utf-8", "replace").strip()}))
            continue

        try:
            with open(tmp_cache, "wb") as out:
                out.write(completed.stdout)
            count = _count_audio_rows(tmp_cache)
            if count <= 0:
                tmp_cache.unlink(missing_ok=True)
                print(json.dumps({"status": "warning", "mirror": mirror, "message": "no audio entries found"}))
                continue
            os.replace(tmp_cache, target_cache)
        except Exception as exc:
            tmp_cache.unlink(missing_ok=True)
            die(f"failed to write cache: {exc}")

        print(json.dumps({"status": "ok", "entries": count, "cache": str(target_cache), "mirror": mirror}))
        return 0

    die("all mirrors failed")


def _iter_results(query, max_hits, filters):
    path = cache_dir() / "audios.xz"
    if not path.exists():
        return 0, []

    lower = (query or "").strip().lower()
    filter_sender = _normalize_entry_value(filters.sender).lower()
    filter_genre = _normalize_entry_value(filters.genre).lower()
    filter_topic = _normalize_entry_value(filters.topic).lower()
    filter_title = _normalize_entry_value(getattr(filters, "title", "")).lower()
    filter_theme_title = _normalize_entry_value(getattr(filters, "theme_title", "")).lower()
    filter_somewhere = _normalize_entry_value(getattr(filters, "somewhere", "")).lower()
    filter_max_days = _normalize_filter_max_days(getattr(filters, "max_days", FILTER_PROFILE_DEFAULT_MAX_DAYS))
    filter_min_duration = _normalize_min_duration(getattr(filters, "min_duration", FILTER_PROFILE_DEFAULT_MIN_DURATION))
    filter_max_duration = _normalize_max_duration(getattr(filters, "max_duration", FILTER_PROFILE_DEFAULT_MAX_DURATION))
    only_new = _normalize_bool_value(getattr(filters, "only_new", False), False)
    only_bookmarks = _normalize_bool_value(getattr(filters, "only_bookmarks", False), False)
    hide_history = _normalize_bool_value(getattr(filters, "hide_history", False), False)
    podcast_mode = _normalize_podcast_mode(getattr(filters, "podcast_mode", FILTER_PROFILE_DEFAULT_PODCAST_MODE))
    bookmark_urls = _store_url_set("bookmarks.json") if only_bookmarks else set()
    history_urls = _store_url_set("history.json") if hide_history else set()
    hits = []
    last_sender = ""
    last_genre = ""
    last_topic = ""
    blacklist_mode = _normalize_entry_value(getattr(filters, "blacklist_mode", "off"))
    if blacklist_mode not in BLACKLIST_MODES:
        blacklist_mode = "off"
    blacklist_rules = _load_blacklist() if blacklist_mode in {"hide", "only"} else []

    for raw in _iter_audio_rows(path):
        if len(raw) < 10:
            continue

        sender = normalize_value(raw[0], last_sender)
        genre = normalize_value(raw[1], last_genre)
        topic = normalize_value(raw[2], last_topic)
        last_sender, last_genre, last_topic = sender, genre, topic

        title = normalize_value(raw[3], "")
        date = normalize_value(raw[4], "") if len(raw) > 4 else ""
        time = normalize_value(raw[5], "") if len(raw) > 5 else ""
        duration = normalize_value(raw[6], "") if len(raw) > 6 else ""
        description = normalize_value(raw[8], "") if len(raw) > 8 else ""
        url = normalize_value(raw[9], "")
        website = normalize_value(raw[10], "") if len(raw) > 10 else ""
        is_new = _parse_audio_bool(raw[11]) if len(raw) > 11 else False
        is_podcast = _parse_audio_bool(raw[12]) if len(raw) > 12 else False
        if not _is_http_url(url):
            continue
        if website and not _is_http_url(website):
            website = ""

        if not url or not title:
            continue

        if not _matches_filter(sender, filter_sender):
            continue
        if not _matches_filter(genre, filter_genre):
            continue
        if not _matches_filter(topic, filter_topic):
            continue
        if not _matches_filter(title, filter_title):
            continue
        if filter_theme_title and not _matches_any_filter((topic, title), filter_theme_title):
            continue
        if filter_somewhere and not _matches_any_filter((date, genre, topic, title, description), filter_somewhere):
            continue
        if not _date_matches_max_days(date, filter_max_days):
            continue
        duration_minutes = _parse_duration_minutes(duration)
        if not _duration_matches(duration_minutes, filter_min_duration, filter_max_duration):
            continue
        if only_new and not is_new:
            continue
        if only_bookmarks and url not in bookmark_urls:
            continue
        if hide_history and url in history_urls:
            continue
        if podcast_mode == "only" and not is_podcast:
            continue
        if podcast_mode == "none" and is_podcast:
            continue

        result_item = {
            "title": title,
            "sender": sender,
            "genre": genre,
            "topic": topic,
            "date": date,
            "time": time,
            "duration": duration,
            "description": description,
            "url": url,
            "website": website,
            "is_new": is_new,
            "podcast": is_podcast,
        }
        if blacklist_mode in {"hide", "only"}:
            is_blacklisted = any(_rule_matches_result(rule, result_item) for rule in blacklist_rules)
            if blacklist_mode == "hide" and is_blacklisted:
                continue
            if blacklist_mode == "only" and not is_blacklisted:
                continue

        haystack = " ".join([sender, genre, topic, title, description, url]).lower()
        if lower and lower not in haystack:
            continue

        hits.append(result_item)
        if len(hits) >= max_hits:
            return len(hits), hits

    return len(hits), hits


def action_search(args):
    count, hits = _iter_results(args.query, args.max, args)
    print(json.dumps({"status": "ok", "query": args.query, "count": count, "results": hits}))


def _safe_filename(value):
    cleaned = re.sub(r"[^A-Za-z0-9._-]", "_", value).strip("._-")
    return cleaned[:120] or "atcinnaradio"


def action_download(args):
    folder = _resolve_download_folder(args.folder)
    try:
        destination = _download_to_file(args.url, folder, args.title)
    except subprocess.CalledProcessError as exc:
        die((exc.stderr or b"").decode("utf-8", "replace").strip() or str(exc))
    except Exception as exc:
        die(str(exc))

    print(json.dumps({"status": "ok", "path": str(destination)}))


def parse_args():
    parser = argparse.ArgumentParser(description="ATCinna catalog helper")
    sub = parser.add_subparsers(dest="action", required=True)

    refresh = sub.add_parser("refresh")
    refresh.add_argument("--mirror", dest="mirror", default="", help="Primary mirror URL")

    search = sub.add_parser("search")
    search.add_argument("--query", default="", help="Search query")
    search.add_argument("--sender", default="", help="Filter by sender")
    search.add_argument("--genre", default="", help="Filter by genre")
    search.add_argument("--topic", default="", help="Filter by topic")
    search.add_argument("--title", default="", help="Filter by title")
    search.add_argument("--theme-title", dest="theme_title", default="", help="Filter by topic or title")
    search.add_argument("--somewhere", default="", help="Filter by date, genre, topic, title, or description")
    search.add_argument("--max-days", default=FILTER_PROFILE_DEFAULT_MAX_DAYS, help="Only show entries from the last N days; 0 disables")
    search.add_argument("--min-duration", default=FILTER_PROFILE_DEFAULT_MIN_DURATION, help="Minimum duration in minutes; 0 disables")
    search.add_argument("--max-duration", default=FILTER_PROFILE_DEFAULT_MAX_DURATION, help="Maximum duration in minutes; 150 disables")
    search.add_argument("--only-new", action="store_true", default=False, help="Only show entries marked new")
    search.add_argument("--only-bookmarks", action="store_true", default=False, help="Only show bookmarked entries")
    search.add_argument("--hide-history", action="store_true", default=False, help="Hide entries already present in history")
    search.add_argument("--podcast-mode", default=FILTER_PROFILE_DEFAULT_PODCAST_MODE, choices=tuple(sorted(PODCAST_MODES)), help="Podcast filter mode")
    search.add_argument("--blacklist-mode", dest="blacklist_mode", default="off", help="Blacklist filter mode", choices=tuple(sorted(BLACKLIST_MODES)))
    search.add_argument("--max", type=int, default=20, dest="max", help="Max results")

    blacklist_add = sub.add_parser("blacklist-add", help="Add blacklist rule")
    blacklist_add.add_argument("--sender", default="", help="Blacklist sender")
    blacklist_add.add_argument("--genre", default="", help="Blacklist genre")
    blacklist_add.add_argument("--topic", default="", help="Blacklist topic")
    blacklist_add.add_argument("--title", default="", help="Blacklist title")
    blacklist_add.add_argument("--theme-title", dest="theme_title", default="", help="Blacklist topic or title")
    blacklist_add.add_argument("--active", default=None, help="Whether rule is active (true/false)")
    blacklist_add.add_argument("--topic-exact", default=None, help="Whether topic matches exactly (true/false)")

    blacklist_list = sub.add_parser("blacklist-list", help="List blacklist rules")

    blacklist_remove = sub.add_parser("blacklist-remove", help="Remove blacklist rules by exact match")
    blacklist_remove.add_argument("--sender", default="", help="Blacklist sender")
    blacklist_remove.add_argument("--genre", default="", help="Blacklist genre")
    blacklist_remove.add_argument("--topic", default="", help="Blacklist topic")
    blacklist_remove.add_argument("--title", default="", help="Blacklist title")
    blacklist_remove.add_argument("--theme-title", dest="theme_title", default="", help="Blacklist topic or title rule")
    blacklist_remove.add_argument("--active", default=None, help="Only remove rules with this active state (true/false)")
    blacklist_remove.add_argument("--topic-exact", default=None, help="Only remove rules with this topic mode (true/false)")

    blacklist_undo = sub.add_parser("blacklist-undo", help="Restore removed blacklist rules")
    sub.add_parser("blacklist-clean", help="Remove empty/duplicate blacklist rules and store removed entries in undo")
    sub.add_parser("blacklist-clear", help="Remove all blacklist rules and store removed entries in undo")

    sub.add_parser("filter-profile-list", help="List saved filter profiles")

    filter_profile_get = sub.add_parser("filter-profile-get", help="Get one saved filter profile")
    filter_profile_get.add_argument("--name", required=True, help="Filter profile name")

    sub.add_parser("filter-profile-next-name", help="Return the next free filter profile name")

    filter_profile_save = sub.add_parser("filter-profile-save", help="Save or update a filter profile")
    filter_profile_save.add_argument("--name", default="", help="Filter profile name; defaults to next free name")
    filter_profile_save.add_argument("--search-query", default="", help="Saved search query")
    filter_profile_save.add_argument("--sender", default="", help="Saved sender filter")
    filter_profile_save.add_argument("--genre", default="", help="Saved genre filter")
    filter_profile_save.add_argument("--topic", default="", help="Saved topic filter")
    filter_profile_save.add_argument("--title", default="", help="Saved title filter")
    filter_profile_save.add_argument("--theme-title", dest="theme_title", default="", help="Saved topic-or-title filter")
    filter_profile_save.add_argument("--somewhere", default="", help="Saved somewhere filter")
    filter_profile_save.add_argument("--blacklist-mode", default=FILTER_PROFILE_DEFAULT_BLACKLIST_MODE, help="Saved blacklist mode")
    filter_profile_save.add_argument("--max-hits", default=FILTER_PROFILE_DEFAULT_MAX_HITS, help="Saved maximum hit count")
    filter_profile_save.add_argument("--max-days", default=FILTER_PROFILE_DEFAULT_MAX_DAYS, help="Saved maximum age in days")
    filter_profile_save.add_argument("--min-duration", default=FILTER_PROFILE_DEFAULT_MIN_DURATION, help="Saved minimum duration in minutes")
    filter_profile_save.add_argument("--max-duration", default=FILTER_PROFILE_DEFAULT_MAX_DURATION, help="Saved maximum duration in minutes")
    filter_profile_save.add_argument("--only-new", action="store_true", default=False, help="Saved only-new filter")
    filter_profile_save.add_argument("--only-bookmarks", action="store_true", default=False, help="Saved only-bookmarks filter")
    filter_profile_save.add_argument("--hide-history", action="store_true", default=False, help="Saved hide-history filter")
    filter_profile_save.add_argument("--podcast-mode", default=FILTER_PROFILE_DEFAULT_PODCAST_MODE, choices=tuple(sorted(PODCAST_MODES)), help="Saved podcast filter mode")

    filter_profile_rename = sub.add_parser("filter-profile-rename", help="Rename a filter profile")
    filter_profile_rename.add_argument("--name", required=True, help="Existing filter profile name")
    filter_profile_rename.add_argument("--new-name", required=True, help="New filter profile name")

    filter_profile_remove = sub.add_parser("filter-profile-remove", help="Remove a filter profile")
    filter_profile_remove.add_argument("--name", required=True, help="Filter profile name")

    sub.add_parser("filter-profile-clear", help="Remove all filter profiles")
    sub.add_parser("filter-profile-reset", help="Restore default filter profiles")
    sub.add_parser("filter-profile-sort", help="Sort filter profiles by name")

    history_add = sub.add_parser("history-add", help="Add history entry")
    history_add.add_argument("--title", default="", help="Optional title")
    history_add.add_argument("--sender", default="", help="Optional sender")
    history_add.add_argument("--genre", default="", help="Optional genre")
    history_add.add_argument("--topic", default="", help="Optional topic")
    history_add.add_argument("--date", default="", help="Optional date")
    history_add.add_argument("--time", default="", help="Optional time")
    history_add.add_argument("--duration", default="", help="Optional duration")
    history_add.add_argument("--description", default="", help="Optional description")
    history_add.add_argument("--url", required=True, help="Content URL")
    history_add.add_argument("--website", default="", help="Optional website URL")

    history_list = sub.add_parser("history-list", help="List history entries")

    bookmark_add = sub.add_parser("bookmark-add", help="Add bookmark entry")
    bookmark_add.add_argument("--title", default="", help="Optional title")
    bookmark_add.add_argument("--sender", default="", help="Optional sender")
    bookmark_add.add_argument("--genre", default="", help="Optional genre")
    bookmark_add.add_argument("--topic", default="", help="Optional topic")
    bookmark_add.add_argument("--date", default="", help="Optional date")
    bookmark_add.add_argument("--time", default="", help="Optional time")
    bookmark_add.add_argument("--duration", default="", help="Optional duration")
    bookmark_add.add_argument("--description", default="", help="Optional description")
    bookmark_add.add_argument("--url", required=True, help="Content URL")
    bookmark_add.add_argument("--website", default="", help="Optional website URL")

    bookmark_remove = sub.add_parser("bookmark-remove", help="Remove bookmark by URL")
    bookmark_remove.add_argument("--url", required=True, help="Content URL")

    bookmark_list = sub.add_parser("bookmark-list", help="List bookmark entries")

    download = sub.add_parser("download")
    download.add_argument("--url", required=True, help="Media URL")
    download.add_argument("--folder", default="", help="Download folder")
    download.add_argument("--title", default="", help="Optional file base title")

    download_enqueue = sub.add_parser("download-enqueue", help="Add media URL to download queue")
    download_enqueue.add_argument("--title", default="", help="Optional title")
    download_enqueue.add_argument("--sender", default="", help="Optional sender")
    download_enqueue.add_argument("--genre", default="", help="Optional genre")
    download_enqueue.add_argument("--topic", default="", help="Optional topic")
    download_enqueue.add_argument("--date", default="", help="Optional date")
    download_enqueue.add_argument("--time", default="", help="Optional time")
    download_enqueue.add_argument("--duration", default="", help="Optional duration")
    download_enqueue.add_argument("--description", default="", help="Optional description")
    download_enqueue.add_argument("--url", required=True, help="Media URL")
    download_enqueue.add_argument("--website", default="", help="Optional website URL")
    download_enqueue.add_argument("--folder", default="", help="Download folder")

    download_list = sub.add_parser("download-list", help="List queue entries")

    download_run_next = sub.add_parser("download-run-next", help="Run next queued download")

    download_cancel = sub.add_parser("download-cancel", help="Cancel queued/running queue entry")
    download_cancel.add_argument("--url", default="", help="Media URL")
    download_cancel.add_argument("--all", action="store_true", default=False, help="Cancel all queued/running entries")
    download_cancel.add_argument("--queued-only", action="store_true", default=False, help="Cancel queued entries only")

    sub.add_parser("download-clear", help="Remove finished/error/cancelled queue entries")
    download_remove = sub.add_parser("download-remove", help="Remove non-running queue entry by URL")
    download_remove.add_argument("--url", required=True, help="Media URL")
    download_update = sub.add_parser("download-update", help="Update queued entry by URL")
    download_update.add_argument("--url", required=True, help="Media URL")
    download_update.add_argument("--title", default=None, help="Optional title")
    download_update.add_argument("--sender", default=None, help="Optional sender")
    download_update.add_argument("--genre", default=None, help="Optional genre")
    download_update.add_argument("--topic", default=None, help="Optional topic")
    download_update.add_argument("--date", default=None, help="Optional date")
    download_update.add_argument("--time", default=None, help="Optional time")
    download_update.add_argument("--duration", default=None, help="Optional duration")
    download_update.add_argument("--description", default=None, help="Optional description")
    download_update.add_argument("--folder", default=None, help="Optional download folder")
    download_update.add_argument("--website", default=None, help="Optional website URL")
    sub.add_parser("download-undo", help="Restore last removed queue entries")
    sub.add_parser("download-trash-file", help="Move stored queue file to trash").add_argument(
        "--url",
        default="",
        help="Media URL"
    )
    download_prefer = sub.add_parser("download-prefer", help="Move queued entry before other queued entries")
    download_prefer.add_argument("--url", required=True, help="Media URL")
    download_put_back = sub.add_parser("download-put-back", help="Move queued entry behind other queued entries")
    download_put_back.add_argument("--url", required=True, help="Media URL")

    return parser.parse_args()


def main():
    args = parse_args()
    if args.action == "refresh":
        action_refresh(args)
    elif args.action == "search":
        action_search(args)
    elif args.action == "blacklist-add":
        action_blacklist_add(args)
    elif args.action == "blacklist-list":
        action_blacklist_list(args)
    elif args.action == "blacklist-remove":
        action_blacklist_remove(args)
    elif args.action == "blacklist-undo":
        action_blacklist_undo(args)
    elif args.action == "blacklist-clean":
        action_blacklist_clean(args)
    elif args.action == "blacklist-clear":
        action_blacklist_clear(args)
    elif args.action == "filter-profile-list":
        action_filter_profile_list(args)
    elif args.action == "filter-profile-get":
        action_filter_profile_get(args)
    elif args.action == "filter-profile-next-name":
        action_filter_profile_next_name(args)
    elif args.action == "filter-profile-save":
        action_filter_profile_save(args)
    elif args.action == "filter-profile-rename":
        action_filter_profile_rename(args)
    elif args.action == "filter-profile-remove":
        action_filter_profile_remove(args)
    elif args.action == "filter-profile-clear":
        action_filter_profile_clear(args)
    elif args.action == "filter-profile-reset":
        action_filter_profile_reset(args)
    elif args.action == "filter-profile-sort":
        action_filter_profile_sort(args)
    elif args.action == "download":
        action_download(args)
    elif args.action == "download-enqueue":
        action_download_enqueue(args)
    elif args.action == "download-list":
        action_download_list(args)
    elif args.action == "download-run-next":
        action_download_run_next(args)
    elif args.action == "download-cancel":
        action_download_cancel(args)
    elif args.action == "download-clear":
        action_download_clear(args)
    elif args.action == "download-remove":
        action_download_remove(args)
    elif args.action == "download-update":
        action_download_update(args)
    elif args.action == "download-undo":
        action_download_undo(args)
    elif args.action == "download-trash-file":
        action_download_trash_file(args)
    elif args.action == "download-prefer":
        action_download_prefer(args)
    elif args.action == "download-put-back":
        action_download_put_back(args)
    elif args.action == "history-add":
        action_history_add(args)
    elif args.action == "history-list":
        action_history_list(args)
    elif args.action == "bookmark-add":
        action_bookmark_add(args)
    elif args.action == "bookmark-remove":
        action_bookmark_remove(args)
    elif args.action == "bookmark-list":
        action_bookmark_list(args)
    else:
        die("unknown action")


if __name__ == "__main__":
    main()
