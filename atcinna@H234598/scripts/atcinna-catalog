]

QUEUE_MAX_ENTRIES = 500
QUEUE_STATUSES = {"queued", "running", "finished", "error", "cancelled"}
UNDO_MAX_ENTRIES = 100
BLACKLIST_MAX_ENTRIES = 500
BLACKLIST_MODES = {"off", "hide", "only"}
BLACKLIST_UNDO_MAX_ENTRIES = 100
PODCAST_MODES = {"all", "only", "none"}
FILTER_PROFILE_MAX_ENTRIES = 100
FILTER_PROFILE_NAME_MAX_LENGTH = 120
FILTER_PROFILE_DEFAULT_BLACKLIST_MODE = "hide"
FILTER_PROFILE_DEFAULT_MAX_HITS = 20
FILTER_PROFILE_DEFAULT_MAX_DAYS = 0
FILTER_PROFILE_DEFAULT_MIN_DURATION = 0
FILTER_PROFILE_DEFAULT_MAX_DURATION = 150
FILTER_PROFILE_DEFAULT_PODCAST_MODE = "all"


def die(message, exit_code=1):
    print(json.dumps({"status": "error", "message": message}), file=sys.stderr)
    raise SystemExit(exit_code)


def cache_dir():
    base = os.environ.get("XDG_CACHE_HOME") or str(Path.home() / ".cache")
    return Path(base) / "atcinna@H234598"


def data_dir():
    base = os.environ.get("XDG_DATA_HOME") or str(Path.home() / ".local/share")
    return Path(base) / "atcinna@H234598"


def ensure_dir(path):
    path.mkdir(parents=True, exist_ok=True)


def normalize_value(value, fallback):
    if isinstance(value, str):
        text = value.strip()
        return text if text else fallback
    return fallback


def _is_http_url(url):
    parsed = urlparse(url)
    return parsed.scheme in ("http", "https") and bool(parsed.netloc)


def _normalize_entry_value(value):
    if isinstance(value, str):
        return value.strip()
    return ""


def _normalize_timestamp(value, default):
    try:
        return int(value)
    except (TypeError, ValueError):
        return default


def _normalize_bool_value(value, default):
    if isinstance(value, bool):
        return value
    if value is None:
        return default
    if isinstance(value, str):
        lowered = value.strip().lower()
        if lowered in {"1", "true", "yes", "on"}:
            return True
        if lowered in {"0", "false", "no", "off"}:
            return False
    return default


def _parse_bool_arg(value, field):
    normalized = _normalize_bool_value(value, None)
    if normalized is None:
        die(f"{field} must be true or false")
    return normalized


def _blacklist_path():
    return data_dir() / "blacklist.json"


def _blacklist_undo_path():
    return data_dir() / "blacklist-undo.json"


def _filter_profiles_path():
    return data_dir() / "filter-profiles.json"


def _load_list(path):
    if not path.exists():
        return []

    try:
        with path.open("r", encoding="utf-8") as handle:
            raw = json.load(handle)
    except (OSError, json.JSONDecodeError):
        return []
    except Exception:
        return []

    if not isinstance(raw, list):
        return []

    return [item for item in raw if isinstance(item, dict)]


def _normalize_blacklist_field(value):
    return _normalize_entry_value(value).lower()


def _normalize_rule(rule):
    if hasattr(rule, "get"):
        getter = lambda key, default="": rule.get(key, default)
    else:
        getter = lambda key, default="": _normalize_entry_value(getattr(rule, key, default))
    try:
        timestamp = int(getter("timestamp", int(time.time())))
    except (TypeError, ValueError):
        timestamp = int(time.time())
    return {
        "sender": _normalize_entry_value(getter("sender")),
        "genre": _normalize_entry_value(getter("genre")),
        "topic": _normalize_entry_value(getter("topic")),
        "title": _normalize_entry_value(getter("title")),
        "theme_title": _normalize_entry_value(getter("theme_title")),
        "timestamp": timestamp,
    }


def _load_blacklist():
    entries = _load_list(_blacklist_path())
    normalized = []
    for entry in entries:
        normalized_entry = _normalize_blacklist_entry(entry)
        if normalized_entry:
            normalized.append(normalized_entry)
    return normalized


def _load_blacklist_undo():
    entries = _load_list(_blacklist_undo_path())
    normalized = []
    for entry in entries:
        normalized_entry = _normalize_blacklist_entry(entry)
        if normalized_entry:
            normalized.append(normalized_entry)
    return normalized


def _store_blacklist_undo(entries):
    _store_list(_blacklist_undo_path(), entries)


def _normalize_filter_profile_name(value):
    name = _normalize_entry_value(value).replace("\x00", "")
    name = re.sub(r"\s+", " ", name)
    return name[:FILTER_PROFILE_NAME_MAX_LENGTH]


def _normalize_blacklist_mode(value, default=FILTER_PROFILE_DEFAULT_BLACKLIST_MODE):
    mode = _normalize_entry_value(value).lower()
    return mode if mode in BLACKLIST_MODES else default


def _normalize_podcast_mode(value, default=FILTER_PROFILE_DEFAULT_PODCAST_MODE):
    mode = _normalize_entry_value(value).lower()
    return mode if mode in PODCAST_MODES else default


def _normalize_max_hits(value, default=FILTER_PROFILE_DEFAULT_MAX_HITS):
    try:
        parsed = int(value)
    except (TypeError, ValueError):
        parsed = default
    return max(1, min(parsed, 100))


def _normalize_int_range(value, default, minimum, maximum):
    try:
        parsed = int(value)
    except (TypeError, ValueError):
        parsed = default
    return max(minimum, min(parsed, maximum))


def _normalize_filter_max_days(value):
    return _normalize_int_range(value, FILTER_PROFILE_DEFAULT_MAX_DAYS, 0, 50)


def _normalize_min_duration(value):
    return _normalize_int_range(value, FILTER_PROFILE_DEFAULT_MIN_DURATION, 0, FILTER_PROFILE_DEFAULT_MAX_DURATION)


def _normalize_max_duration(value):
    return _normalize_int_range(value, FILTER_PROFILE_DEFAULT_MAX_DURATION, 0, FILTER_PROFILE_DEFAULT_MAX_DURATION)


def _normalize_filter_profile(profile):
    if not isinstance(profile, dict):
        return None
    name = _normalize_filter_profile_name(profile.get("name"))
    if not name:
        return None
    return {
        "name": name,
        "search_query": _normalize_entry_value(profile.get("search_query")),
        "sender": _normalize_entry_value(profile.get("sender")),
        "genre": _normalize_entry_value(profile.get("genre")),
        "topic": _normalize_entry_value(profile.get("topic")),
        "title": _normalize_entry_value(profile.get("title")),
        "theme_title": _normalize_entry_value(profile.get("theme_title")),
        "somewhere": _normalize_entry_value(profile.get("somewhere")),
        "blacklist_mode": _normalize_blacklist_mode(profile.get("blacklist_mode")),
        "max_hits": _normalize_max_hits(profile.get("max_hits")),
        "max_days": _normalize_filter_max_days(profile.get("max_days")),
        "min_duration": _normalize_min_duration(profile.get("min_duration")),
        "max_duration": _normalize_max_duration(profile.get("max_duration")),
        "only_new": _normalize_bool_value(profile.get("only_new"), False),
        "only_bookmarks": _normalize_bool_value(profile.get("only_bookmarks"), False),
        "hide_history": _normalize_bool_value(profile.get("hide_history"), False),
        "podcast_mode": _normalize_podcast_mode(profile.get("podcast_mode")),
        "timestamp": _normalize_timestamp(profile.get("timestamp"), int(time.time())),
    }


