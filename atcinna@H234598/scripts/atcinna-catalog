def _filter_profile_key(profile_or_name):
    if isinstance(profile_or_name, dict):
        name = profile_or_name.get("name")
    else:
        name = profile_or_name
    return _normalize_filter_profile_name(name).casefold()


def _load_filter_profiles():
    path = _filter_profiles_path()
    raw_entries = _load_list(path) if path.exists() else _default_filter_profiles()
    profiles = []
    seen = set()
    for entry in raw_entries:
        profile = _normalize_filter_profile(entry)
        if not profile:
            continue
        key = _filter_profile_key(profile)
        if key in seen:
            continue
        seen.add(key)
        profiles.append(profile)
    return profiles


def _store_filter_profiles(profiles):
    normalized = []
    seen = set()
    for entry in profiles:
        profile = _normalize_filter_profile(entry)
        if not profile:
            continue
        key = _filter_profile_key(profile)
        if key in seen:
            continue
        seen.add(key)
        normalized.append(profile)
    if FILTER_PROFILE_MAX_ENTRIES > 0:
        normalized = normalized[:FILTER_PROFILE_MAX_ENTRIES]
    _store_list(_filter_profiles_path(), normalized)
    return normalized


def _next_filter_profile_name(profiles):
    existing = {_filter_profile_key(profile) for profile in profiles}
    index = 1
    while True:
        candidate = f"Filter {index}"
        if candidate.casefold() not in existing:
            return candidate
        index += 1


def _profile_from_args(args, profiles):
    name = _normalize_filter_profile_name(getattr(args, "name", ""))
    if not name:
        name = _next_filter_profile_name(profiles)
    return _normalize_filter_profile({
        "name": name,
        "search_query": getattr(args, "search_query", ""),
        "sender": getattr(args, "sender", ""),
        "genre": getattr(args, "genre", ""),
        "topic": getattr(args, "topic", ""),
        "title": getattr(args, "title", ""),
        "theme_title": getattr(args, "theme_title", ""),
        "somewhere": getattr(args, "somewhere", ""),
        "blacklist_mode": getattr(args, "blacklist_mode", FILTER_PROFILE_DEFAULT_BLACKLIST_MODE),
        "max_hits": getattr(args, "max_hits", FILTER_PROFILE_DEFAULT_MAX_HITS),
        "max_days": getattr(args, "max_days", FILTER_PROFILE_DEFAULT_MAX_DAYS),
        "min_duration": getattr(args, "min_duration", FILTER_PROFILE_DEFAULT_MIN_DURATION),
        "max_duration": getattr(args, "max_duration", FILTER_PROFILE_DEFAULT_MAX_DURATION),
        "only_new": getattr(args, "only_new", False),
        "only_bookmarks": getattr(args, "only_bookmarks", False),
        "hide_history": getattr(args, "hide_history", False),
        "podcast_mode": getattr(args, "podcast_mode", FILTER_PROFILE_DEFAULT_PODCAST_MODE),
        "timestamp": int(time.time()),
    })


def _store_list(path, items):
    ensure_dir(path.parent)
    tmp = path.with_name(f".{path.name}.{os.getpid()}.tmp")
    try:
        with tmp.open("w", encoding="utf-8") as handle:
            json.dump(items, handle, ensure_ascii=False)
            handle.flush()
            os.fsync(handle.fileno())
        os.replace(tmp, path)
        dir_fd = os.open(path.parent, os.O_DIRECTORY)
        try:
            os.fsync(dir_fd)
        finally:
            os.close(dir_fd)
    finally:
        tmp.unlink(missing_ok=True)


@contextlib.contextmanager
def _store_lock(path):
    ensure_dir(path.parent)
    lock_path = path.with_name(f"{path.name}.lock")
    with lock_path.open("a", encoding="utf-8") as handle:
        fcntl.flock(handle, fcntl.LOCK_EX)
        try:
            yield
        finally:
            fcntl.flock(handle, fcntl.LOCK_UN)


def _entry_from_args(args):
    return {
        "title": _normalize_entry_value(args.title),
        "sender": _normalize_entry_value(args.sender),
        "genre": _normalize_entry_value(args.genre),
        "topic": _normalize_entry_value(args.topic),
        "date": _normalize_entry_value(getattr(args, "date", "")),
        "time": _normalize_entry_value(getattr(args, "time", "")),
        "duration": _normalize_entry_value(getattr(args, "duration", "")),
        "description": _normalize_entry_value(getattr(args, "description", "")),
        "url": _normalize_entry_value(args.url),
        "website": _normalize_entry_value(args.website),
        "timestamp": int(time.time()),
    }


def _add_to_store(path, args, max_entries):
    item = _entry_from_args(args)
    if not item["url"]:
        die("url is required")
    with _store_lock(path):
        entries = _load_list(path)
        entries = [entry for entry in entries if _normalize_entry_value(entry.get("url")) != item["url"]]
        entries.insert(0, item)
        if max_entries > 0:
            entries = entries[:max_entries]
        _store_list(path, entries)


def _list_store(path):
    entries = _load_list(path)
    print(json.dumps({"status": "ok", "count": len(entries), "results": entries}))


def action_blacklist_add(args):
    # pylint: disable=too-many-locals
    rule = _normalize_rule(args)
    if not (rule["sender"] or rule["genre"] or rule["topic"] or rule["title"] or rule["theme_title"]):
        die("at least one blacklist field is required")

    active = _parse_bool_arg(args.active, "active") if args.active is not None else True
    topic_exact = _parse_bool_arg(args.topic_exact, "topic-exact") if args.topic_exact is not None else True
    path = _blacklist_path()
    with _store_lock(path):
        entries = _load_blacklist()
        target = _load_blacklist_rule({
            **rule,
            "active": active,
            "topic_exact": topic_exact,
            "timestamp": int(time.time()),
        })
        target_key = _blacklist_rule_key(target)
        filtered = [
            entry for entry in entries
            if _blacklist_rule_key(entry) != target_key
        ]
        target["timestamp"] = int(time.time())
        filtered.insert(0, target)
        if BLACKLIST_MAX_ENTRIES > 0:
            filtered = filtered[:BLACKLIST_MAX_ENTRIES]
        _store_list(path, filtered)
    print(json.dumps({"status": "ok", "count": len(filtered)}))


def action_blacklist_list(args):
    entries = _load_blacklist()
    print(json.dumps({"status": "ok", "count": len(entries), "results": entries}))


def action_blacklist_remove(args):
    target_rule = _normalize_blacklist_entry(_normalize_rule(args))
    target_sender = target_rule["sender"]
    target_genre = target_rule["genre"]
    target_topic = target_rule["topic"]
    target_title = target_rule["title"]
    target_theme_title = target_rule["theme_title"]
    target_active = _parse_bool_arg(args.active, "active") if args.active is not None else None
    target_topic_exact = _parse_bool_arg(args.topic_exact, "topic-exact") if args.topic_exact is not None else None
    if not (target_sender or target_genre or target_topic or target_title or target_theme_title):
        die("at least one blacklist field is required")

    path = _blacklist_path()
    with _store_lock(path):
        entries = _load_blacklist()
        filtered = []
        removed_entries = []
        removed = 0
        for entry in entries:
            normalized = _normalize_blacklist_entry(entry)
            matches = (
                (not target_sender or normalized["sender"] == target_sender) and
                (not target_genre or normalized["genre"] == target_genre) and
                (not target_topic or normalized["topic"] == target_topic) and
                (not target_title or normalized["title"] == target_title) and
                (not target_theme_title or normalized["theme_title"] == target_theme_title) and
                (target_active is None or normalized["active"] == target_active) and
                (target_topic_exact is None or normalized["topic_exact"] == target_topic_exact)
            )
            if matches:
                removed_entries.append(entry)
                removed += 1
            else:
                filtered.append(entry)
        if removed:
            _store_list(path, filtered)
            undo_entries = _load_blacklist_undo()
            undo_entries.extend(removed_entries)
            if BLACKLIST_UNDO_MAX_ENTRIES > 0:
                undo_entries = undo_entries[-BLACKLIST_UNDO_MAX_ENTRIES:]
            _store_blacklist_undo(undo_entries)
    print(json.dumps({"status": "ok", "removed": removed}))


def action_blacklist_clean(args):
    path = _blacklist_path()
    with _store_lock(path):
        entries = _load_blacklist()
        kept = []
        removed_entries = []
        seen = set()
        for entry in entries:
            rule_key = _blacklist_rule_key(entry)
            if _blacklist_rule_is_empty(entry) or rule_key in seen:
                removed_entries.append(entry)
            else:
                seen.add(rule_key)
                kept.append(entry)
        if removed_entries:
            _store_list(path, kept)
            undo_entries = _load_blacklist_undo()
            undo_entries.extend(removed_entries)
            if BLACKLIST_UNDO_MAX_ENTRIES > 0:
                undo_entries = undo_entries[-BLACKLIST_UNDO_MAX_ENTRIES:]
            _store_blacklist_undo(undo_entries)
    print(json.dumps({"status": "ok", "removed": len(removed_entries)}))


def action_blacklist_clear(args):
    path = _blacklist_path()
    with _store_lock(path):
        entries = _load_blacklist()
        if entries:
            _store_list(path, [])
            undo_entries = _load_blacklist_undo()
            undo_entries.extend(entries)
            if BLACKLIST_UNDO_MAX_ENTRIES > 0:
                undo_entries = undo_entries[-BLACKLIST_UNDO_MAX_ENTRIES:]
            _store_blacklist_undo(undo_entries)
    print(json.dumps({"status": "ok", "removed": len(entries)}))


def action_blacklist_undo(args):
    with _store_lock(_blacklist_path()):
        entries = _load_blacklist()
        undo_entries = _load_blacklist_undo()
        restored = []
        existing = {_blacklist_rule_key(entry) for entry in entries}
        to_restore = []
        for entry in reversed(undo_entries):
            if _blacklist_rule_is_empty(entry):
                continue
            rule_key = _blacklist_rule_key(entry)
            if rule_key in existing:
                continue
            existing.add(rule_key)
            restored.append(entry)
            to_restore.append(_normalize_blacklist_entry(entry))
        if to_restore:
            entries.extend(to_restore)
            if BLACKLIST_MAX_ENTRIES > 0:
                entries = entries[-BLACKLIST_MAX_ENTRIES:]
            _store_list(_blacklist_path(), entries)
        if undo_entries:
            _store_blacklist_undo([])
    print(json.dumps({"status": "ok", "restored": len(restored)}))


def action_filter_profile_list(args):
    profiles = _load_filter_profiles()
    print(json.dumps({"status": "ok", "count": len(profiles), "results": profiles}, ensure_ascii=False))


def action_filter_profile_get(args):
    target_key = _filter_profile_key(args.name)
    if not target_key:
        die("name is required")
    for profile in _load_filter_profiles():
        if _filter_profile_key(profile) == target_key:
            print(json.dumps({"status": "ok", "profile": profile}, ensure_ascii=False))
            return
    die("filter profile not found", exit_code=2)


def action_filter_profile_next_name(args):
    profiles = _load_filter_profiles()
    print(json.dumps({"status": "ok", "name": _next_filter_profile_name(profiles)}, ensure_ascii=False))


def action_filter_profile_save(args):
    path = _filter_profiles_path()
    with _store_lock(path):
        profiles = _load_filter_profiles()
        profile = _profile_from_args(args, profiles)
        if not profile:
            die("invalid filter profile")
        target_key = _filter_profile_key(profile)
        filtered = [entry for entry in profiles if _filter_profile_key(entry) != target_key]
        filtered.append(profile)
        profiles = _store_filter_profiles(filtered)
    print(json.dumps({"status": "ok", "count": len(profiles), "profile": profile}, ensure_ascii=False))


def action_filter_profile_rename(args):
    old_key = _filter_profile_key(args.name)
    new_name = _normalize_filter_profile_name(args.new_name)
    if not old_key or not new_name:
        die("name and new-name are required")
    path = _filter_profiles_path()
    with _store_lock(path):
        profiles = _load_filter_profiles()
        new_key = _filter_profile_key(new_name)
        if any(_filter_profile_key(profile) == new_key for profile in profiles if _filter_profile_key(profile) != old_key):
            die("filter profile already exists")
        changed = False
        for profile in profiles:
            if _filter_profile_key(profile) == old_key:
                profile["name"] = new_name
                profile["timestamp"] = int(time.time())
                changed = True
                break
        if not changed:
            die("filter profile not found", exit_code=2)
        profiles = _store_filter_profiles(profiles)
    print(json.dumps({"status": "ok", "count": len(profiles), "name": new_name}, ensure_ascii=False))


def action_filter_profile_remove(args):
    target_key = _filter_profile_key(args.name)
    if not target_key:
        die("name is required")
    path = _filter_profiles_path()
    with _store_lock(path):
        profiles = _load_filter_profiles()
        kept = [entry for entry in profiles if _filter_profile_key(entry) != target_key]
        removed = len(profiles) - len(kept)
        if removed:
            profiles = _store_filter_profiles(kept)
    print(json.dumps({"status": "ok", "removed": removed}, ensure_ascii=False))


def action_filter_profile_clear(args):
    path = _filter_profiles_path()
    with _store_lock(path):
        profiles = _load_filter_profiles()
        _store_filter_profiles([])
    print(json.dumps({"status": "ok", "removed": len(profiles)}, ensure_ascii=False))


def action_filter_profile_reset(args):
    path = _filter_profiles_path()
    with _store_lock(path):
        profiles = _store_filter_profiles(_default_filter_profiles())
    print(json.dumps({"status": "ok", "count": len(profiles), "results": profiles}, ensure_ascii=False))


def action_filter_profile_sort(args):
    path = _filter_profiles_path()
    with _store_lock(path):
        profiles = sorted(_load_filter_profiles(), key=lambda profile: profile["name"].casefold())
        profiles = _store_filter_profiles(profiles)
    print(json.dumps({"status": "ok", "count": len(profiles), "results": profiles}, ensure_ascii=False))


def _validate_and_normalize_url(field_name, value):
    if value and not _is_http_url(value):
        if field_name == "url":
            die("invalid URL scheme")
        die(f"invalid {field_name} URL scheme")


def _load_blacklist_rule(rule):
    if not isinstance(rule, dict):
        return None
    normalized = _normalize_rule(rule)
    return {
        "sender": normalized["sender"].lower(),
        "genre": normalized["genre"].lower(),
        "topic": normalized["topic"].lower(),
        "title": normalized["title"].lower(),
        "theme_title": normalized["theme_title"].lower(),
        "active": _normalize_bool_value(rule.get("active"), True),
        "topic_exact": _normalize_bool_value(rule.get("topic_exact"), True),
        "timestamp": _normalize_timestamp(rule.get("timestamp"), normalized["timestamp"]),
    }


def _normalize_blacklist_entry(entry):
    return _load_blacklist_rule(entry)


def _blacklist_rule_is_empty(rule):
    return not (
        _normalize_blacklist_field(rule.get("sender"))
        or _normalize_blacklist_field(rule.get("genre"))
        or _normalize_blacklist_field(rule.get("topic"))
        or _normalize_blacklist_field(rule.get("title"))
        or _normalize_blacklist_field(rule.get("theme_title"))
    )


def _blacklist_rule_key(rule):
    topic = _normalize_blacklist_field(rule.get("topic"))
    return (
        _normalize_blacklist_field(rule.get("sender")),
        _normalize_blacklist_field(rule.get("genre")),
        topic,
        _normalize_blacklist_field(rule.get("title")),
        _normalize_blacklist_field(rule.get("theme_title")),
        _normalize_bool_value(rule.get("topic_exact"), True) if topic else True,
    )


def _rule_matches_result(rule, item):
    if not _normalize_bool_value(rule.get("active"), True):
        return False

    fields = {
        "sender": _normalize_blacklist_field(item.get("sender")),
        "genre": _normalize_blacklist_field(item.get("genre")),
        "topic": _normalize_blacklist_field(item.get("topic")),
        "title": _normalize_blacklist_field(item.get("title")),
        "theme_title": "",
    }
    for key, rule_value in rule.items():
        if key == "timestamp":
            continue
        if key not in fields:
            continue
        if not rule_value:
            continue
        item_value = fields.get(key, "")
        if key == "topic" and _normalize_bool_value(rule.get("topic_exact"), True):
            matches = item_value == rule_value
        elif key == "topic":
            matches = rule_value in item_value
        elif key == "theme_title":
            topic_text = fields.get("topic", "")
            title_text = fields.get("title", "")
            matches = rule_value in topic_text or rule_value in title_text
        else:
            matches = rule_value in item_value
        if not matches:
            return False
    return True


def _matches_filter(value, needle):
    text = _normalize_entry_value(value).lower()
    expression = _normalize_entry_value(needle).lower()
    if not expression:
        return True
    groups = [group.strip() for group in expression.split(",") if group.strip()]
    if not groups:
        return True
    for group in groups:
        terms = [term.strip() for term in group.split(":") if term.strip()]
        if terms and all(term in text for term in terms):
            return True
    return False


def _matches_any_filter(values, needle):
    expression = _normalize_entry_value(needle).lower()
    if not expression:
        return True
    return any(_matches_filter(value, expression) for value in values)


def _store_url_set(filename):
    path = data_dir() / filename
    return {
        _normalize_entry_value(entry.get("url"))
        for entry in _load_list(path)
        if _normalize_entry_value(entry.get("url"))
    }


def _parse_date_value(value):
    text = _normalize_entry_value(value)
    if not text:
        return None
    head = text.split()[0]
    formats = ("%Y-%m-%d", "%d.%m.%Y", "%Y%m%d")
    for fmt in formats:
        try:
            return datetime.strptime(head, fmt).date()
        except ValueError:
            continue
    return None


def _date_matches_max_days(value, max_days):
    if max_days <= 0:
        return True
    parsed = _parse_date_value(value)
    if parsed is None:
        return True
    cutoff = date_cls.today() - timedelta(days=max_days)
    return parsed >= cutoff


def _parse_duration_minutes(value):
    text = _normalize_entry_value(value)
    if not text:
        return 0
    parts = [int(part) for part in re.findall(r"\d+", text)]
    if not parts:
        return 0
    if ":" in text:
        if len(parts) >= 3:
            seconds = parts[-3] * 3600 + parts[-2] * 60 + parts[-1]
        elif len(parts) == 2:
            seconds = parts[0] * 60 + parts[1]
        else:
            seconds = parts[0] * 60
        return (seconds + 59) // 60 if seconds > 0 else 0
    value_int = parts[0]
    if value_int > FILTER_PROFILE_DEFAULT_MAX_DURATION * 2:
        return (value_int + 59) // 60
    return value_int


def _duration_matches(duration_minutes, min_duration, max_duration):
    if duration_minutes == 0:
        return True
    if min_duration > 0 and duration_minutes < min_duration:
        return False
    if max_duration < FILTER_PROFILE_DEFAULT_MAX_DURATION and duration_minutes > max_duration:
        return False
    return True


def _parse_audio_bool(value):
    text = _normalize_entry_value(value).lower()
    return text in {"1", "true", "yes", "on", "ja", "j", "x"}


